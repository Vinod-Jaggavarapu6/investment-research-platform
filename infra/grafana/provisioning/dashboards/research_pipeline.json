{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["investment-research", "pipeline"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Research Pipeline",
  "uid": "inv-res-pipeline",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(agent_duration_seconds_count, route)",
        "hide": 0,
        "includeAll": true,
        "label": "Route",
        "multi": true,
        "name": "route",
        "options": [],
        "query": {
          "query": "label_values(agent_duration_seconds_count, route)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Agent Node Duration p95 by Node",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(agent_duration_seconds_bucket{route=~\"$route\"}[$__rate_interval])) by (le, node_name))",
          "legendFormat": "p50 — {{node_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(agent_duration_seconds_bucket{route=~\"$route\"}[$__rate_interval])) by (le, node_name))",
          "legendFormat": "p95 — {{node_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" },
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^p50.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^p95.*" },
            "properties": [
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cache_hit_total{result=\"hit\"}[$__rate_interval])) / sum(rate(cache_hit_total[$__rate_interval]))",
          "legendFormat": "Hit Rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cache_hit_total{result=\"hit\"}[$__rate_interval]))",
          "legendFormat": "Hits/s",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(cache_hit_total{result=\"miss\"}[$__rate_interval]))",
          "legendFormat": "Misses/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Hit Rate" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "unit", "value": "percentunit" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Hits/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Misses/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "unit", "value": "short" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
    {
      "id": 3,
      "title": "LLM Token Usage — Input / Cached / Output",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_tokens_total{token_type=\"input\"}[$__rate_interval])) by (model)",
          "legendFormat": "input — {{model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_tokens_total{token_type=\"cache_read\"}[$__rate_interval])) by (model)",
          "legendFormat": "cached — {{model}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(llm_tokens_total{token_type=\"output\"}[$__rate_interval])) by (model)",
          "legendFormat": "output — {{model}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 8,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^input.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^cached.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^output.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "title": "Research Requests by Route",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(research_requests_total{status=\"completed\"}[$__rate_interval])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(research_requests_total{status=\"error\"}[$__rate_interval])) by (route)",
          "legendFormat": "error — {{route}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "unit": "reqps",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^error.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["mean", "sum", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ]
}
